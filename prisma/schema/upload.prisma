model Upload {
    id           String @id @default(cuid())
    fileName     String
    originalName String
    mimetype     String
    size         Int // MB
    url          String
    publicId     String

    userId String
    user   User   @relation(fields: [userId], references: [id])

    file   File?   @relation(fields: [fileId], references: [id])
    fileId String?

    createdAt DateTime @default(now())
}
